# Copy to .env and fill in (most values come from the Bicep/azd outputs).
# Locally: `az login` provides the keyless credential; leave API_KEYS empty to disable the gate.

# --- Azure OpenAI (Responses API: clarifier, lead orchestrator, report) ---
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_VERSION="2025-03-01-preview"
MAIN_MODEL="gpt-4.1"
MINI_MODEL="gpt-4.1-mini"
OPENAI_MAX_RETRIES="5"

# --- Azure AI Foundry project + Grounding with Bing ---
AZURE_AI_PROJECT_ENDPOINT=""   # .../api/projects/<name>
BING_CONNECTION_ID=""          # Foundry connection id for Grounding with Bing

# Agent names the app resolves at runtime (must match utils/sync_agents.py).
LEAD_AGENT_NAME="deep-research-lead"
RESEARCHER_AGENT_NAME="deep-research-researcher"
REPORT_AGENT_NAME="deep-research-report"

# --- Orchestration caps (cost guards) ---
MAX_SUBAGENTS_PER_RUN="5"          # hard ceiling on researcher sub-agents per run
MAX_PARALLEL_RESEARCHERS="3"       # semaphore on concurrent researchers
MAX_DELEGATION_ROUNDS="3"          # lead re-planning rounds
SUBAGENTS_PER_ROUND="3"            # max subtasks the lead may request per round (schema 1..N)
MAX_SEARCHES_PER_RESEARCHER="5"    # SOFT: injected into the researcher prompt
RESEARCHER_MAX_COMPLETION_TOKENS="0"  # 0 = unset
MAX_CLARIFY_ROUNDS="3"             # interactive clarification turns before a plan is forced

# --- Observability ---
APPLICATIONINSIGHTS_CONNECTION_STRING=""
ENABLE_TRACING="true"
TRACE_CONTENT="false"              # capture prompt/completion content in spans (privacy: off by default)

# --- Content safety (input guardrail / Prompt Shields) ---
AZURE_CONTENT_SAFETY_ENDPOINT=""
ENABLE_CONTENT_SAFETY="true"
CONTENT_SAFETY_FAIL_OPEN="true"

# --- Access control (per-user keys) ---
API_KEY_STORE="env"               # "env" or "table"
API_KEYS=""                       # comma-separated name:sha256hex (mint with utils/mint_key.py)
AZURE_TABLE_ENDPOINT=""           # for API_KEY_STORE=table
API_KEYS_TABLE="apikeys"
MAX_RUNS_PER_KEY_PER_DAY="3"

# --- Email (Azure Communication Services) ---
ACS_CONNECTION_STRING=""          # from Key Vault in the cloud
ACS_SENDER_ADDRESS=""             # donotreply@<auto>.azurecomm.net
